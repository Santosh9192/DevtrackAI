# DevTrack AI - Environment Configuration

# Backend
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=True

# Database (MySQL)
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/devtrack_ai

# Google Gemini AI (Optional - Mock Mode will be used if empty)
GEMINI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
